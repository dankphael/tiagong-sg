```gitignore
# Dependencies
node_modules/

# Environment variables
.env
.env.local
*.env.*

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Temporary files
*.tmp

# Build artifacts
dist/
build/
*.pyc
__pycache__/
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# Coverage reports
coverage/
htmlcov/
.coverage

# Python specific
*.pyc
__pycache__/
.pytest_cache/
.mypy_cache/

# System files
.DS_Store
Thumbs.db
```